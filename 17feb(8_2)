/*wap to find largets amongst 3 number by using all these function types
 and classes and objects*/

 // with arguments and without return type 

 #include <iostream>
using namespace std;

class Largest
{
public:
    void findLargest(int a, int b, int c)   // with arguments, no return type
    {
        int max = a;

        if (b > max)
            max = b;
        if (c > max)
            max = c;

        cout << "Largest number is: " << max;
    }
};

int main()
{
    int x, y, z;
    cout << "Enter three numbers: ";
    cin >> x >> y >> z;

    Largest obj;                    // object creation
    obj.findLargest(x, y, z);       // passing arguments
    return 0;
}
