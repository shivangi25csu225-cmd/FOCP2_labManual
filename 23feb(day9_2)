 #include <iostream>
# include <string>
using namespace std;
class Candy{
    string color;
    int points;
    public:
    void setCandy(string c, int p){
        color = c;
        points = p;
    }
    void displayCandy(){
        cout<<" The color of the candy is:"<<color<<endl;
        cout<<" The points awarded to the user is:"<<points<<endl;
    }
};
int main(){
    Candy c1, c2;                  // used two class object 
    
    c1.setCandy("Red",89);
    c1.displayCandy();
    c2.setCandy("Green", 64);
    c2.displayCandy();
    return 0;

}
