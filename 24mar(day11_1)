        cin>> focp_num>> phy_num>> chem_num;
        
        avg= (focp_num+ phy_num+ chem_num )/3;
    }
    void display(){
        cout<<" Average marks is :"<<avg<<endl;
    }
};
int main(){
    Test s1;
