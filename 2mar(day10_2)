#include <iostream>
using namespace std;

// Function to calculate volume of a cube
float volume(float side)
{
    return side * side * side;
}

// Function to calculate volume of a cuboid
float volume(float length, float breadth, float height)
{
    return length * breadth * height;
}

// Function to calculate volume of a cylinder
float volume(float radius, float height)
{
    return 3.14 * radius * radius * height;
}

int main()
{
    float side = 4;
    float length = 5, breadth = 3, height = 2;
    float radius = 3, cylHeight = 7;

    cout << "Volume of Cube: " << volume(side) << endl;
    cout << "Volume of Cuboid: " << volume(length, breadth, height) << endl;
    cout << "Volume of Cylinder: " << volume(radius, cylHeight) << endl;

    return 0;
}
