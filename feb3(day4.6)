// zoo problem: hackerearth 
  
  #include <iostream>
using namespace std;

int main() {
    string s;
    cin >> s;

    int z = 0, o = 0;
    int i = 0;

    while (i < s.length() && s[i] == 'z') {
        z++;
        i++;
    }
    while (i < s.length() && s[i] == 'o') {
        o++;
        i++;
    }
    // Check condition
    if (o == 2 * z)
        cout << "Yes";
    else
        cout << "No";

    return 0;
}
